  {
    "type": "separator",
    "label": "Ollama"
  },
  {
    "property": "extensions.zen.rename_pinned_tab.ollama_base_url",
    "label": "Ollama chat URL",
    "type": "string",
    "placeholder": "http://localhost:11434/api/chat",
    "defaultValue": "http://localhost:11434/api/chat",
    "description": "Native Ollama /api/chat endpoint. No API key.",
    "conditions": [
      {
        "if": {
          "property": "extensions.zen.rename_pinned_tab.provider",
          "value": "ollama"
        }
      }
    ]
  },
  {
    "property": "extensions.zen.rename_pinned_tab.ollama_model",
    "label": "Ollama model name",
    "type": "string",
    "placeholder": "mistral",
    "defaultValue": "mistral",
    "conditions": [
      {
        "if": {
          "property": "extensions.zen.rename_pinned_tab.provider",
          "value": "ollama"
        }
      }
    ]
  },
  {
    "type": "separator",
    "label": "Revert"
  },
  {
    "property": "extensions.zen.rename_pinned_tab.revert_modifier",
    "type": "string",
    "label": "Revert shortcut: shift | alt | meta (Shift+click / Alt+click / Cmd+click on tab icon)",
    "defaultValue": "shift"
  }
]
