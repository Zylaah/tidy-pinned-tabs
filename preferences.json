      },
      {
        "value": "gpt-5.4-mini",
        "label": "GPT-5.4 Mini"
      },
      {
        "value": "gpt-5.4-nano",
        "label": "GPT-5.4 Nano"
      },
      {
        "value": "gpt-4o",
        "label": "GPT-4o"
      },
      {
        "value": "gpt-4-turbo",
