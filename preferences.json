[
  {
    "property": "extensions.zen.rename_pinned_tab.enabled",
    "type": "checkbox",
    "label": "Enable AI rename when a tab is pinned",
    "defaultValue": true
  },
  {
    "property": "extensions.zen.rename_pinned_tab.debug",
    "type": "checkbox",
    "label": "Log debug messages to the browser console",
    "defaultValue": false
  },
  {
    "property": "extensions.zen.rename_pinned_tab.provider",
    "label": "LLM provider",
    "type": "dropdown",
    "defaultValue": "mistral",
    "description": "Uses the same API shapes as URL Bar LLM: OpenAI-style chat/completions, native Ollama /api/chat, Gemini OpenAI-compatible endpoint.",
    "options": [
      {
        "value": "mistral",
        "label": "Mistral"
      },
      {
        "value": "openai",
        "label": "OpenAI"
      },
      {
        "value": "ollama",
        "label": "Ollama (local)"
      },
      {
        "value": "gemini",
        "label": "Google Gemini"
      }
    ],
    "conditions": [
      {
        "if": {
          "property": "extensions.zen.rename_pinned_tab.enabled",
          "value": true
        }
      }
    ]
  },
  {
    "type": "separator",
    "label": "Mistral"
  },
  {
    "property": "extensions.zen.rename_pinned_tab.mistral_api_key",
    "label": "Mistral API key",
    "type": "string",
    "placeholder": "Paste API key",
    "description": "api.mistral.ai — same key as other Zen AI mods is fine.",
    "conditions": [
      {
        "if": {
          "property": "extensions.zen.rename_pinned_tab.provider",
          "value": "mistral"
        }
      }
    ]
  },
  {
    "property": "extensions.zen.rename_pinned_tab.mistral_model",
    "label": "Mistral model",
    "type": "dropdown",
    "defaultValue": "mistral-small-latest",
    "description": "Chat completions model for title shortening.",
    "options": [
      {
        "value": "mistral-large-2512",
        "label": "Mistral Large 3"
      },
      {
        "value": "mistral-medium-2505",
        "label": "Mistral Medium 3"
      },
      {
        "value": "mistral-small-latest",
        "label": "Mistral Small Latest"
      },
      {
        "value": "open-mistral-nemo",
        "label": "Mistral Nemo"
      },
      {
        "value": "ministral-8b-latest",
        "label": "Ministral 8B"
      },
      {
        "value": "ministral-3b-latest",
        "label": "Ministral 3B"
      }
    ],
    "conditions": [
      {
        "if": {
          "property": "extensions.zen.rename_pinned_tab.provider",
          "value": "mistral"
        }
      }
    ]
  },
  {
    "type": "separator",
    "label": "OpenAI"
  },
  {
    "property": "extensions.zen.rename_pinned_tab.openai_api_key",
    "label": "OpenAI API key",
    "type": "string",
    "placeholder": "sk-…",
    "conditions": [
      {
        "if": {
          "property": "extensions.zen.rename_pinned_tab.provider",
          "value": "openai"
        }
      }
    ]
  },
  {
    "property": "extensions.zen.rename_pinned_tab.openai_model",
    "label": "OpenAI model",
    "type": "dropdown",
    "defaultValue": "gpt-5.3-chat-latest",
