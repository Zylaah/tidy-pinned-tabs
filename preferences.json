      },
      {
        "value": "gpt-4",
        "label": "GPT-4"
      },
      {
        "value": "gpt-3.5-turbo",
        "label": "GPT-3.5 Turbo"
      }
    ],
    "conditions": [
      {
        "if": {
          "property": "extensions.zen.rename_pinned_tab.provider",
          "value": "openai"
        }
      }
    ]
  },
  {
    "type": "separator",
    "label": "Gemini"
  },
  {
    "property": "extensions.zen.rename_pinned_tab.gemini_api_key",
    "label": "Gemini API key",
    "type": "string",
    "placeholder": "Google AI Studio API key",
